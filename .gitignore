# f2a — .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test & Coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Manual test folder
test/

# Output
examples/output/
examples/sample_data.csv
output/*.html

# Allow sample reports
!sample/

# mypy
.mypy_cache/

# ruff
.ruff_cache/
